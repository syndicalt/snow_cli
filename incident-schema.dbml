  child_incidents int
  calendar_stc int
  close_code varchar(255)
  origin_table varchar(255)
  rfc varchar(32) [ref: > change_request.sys_id]
  incident_state int
  reopen_count int
  resolved_at datetime
  caused_by varchar(32) [ref: > change_request.sys_id]
  category varchar(255)
  sys_id varchar(255) [pk]
  business_stc int
  origin_id varchar(255)
  business_impact varchar(255)
  parent_incident varchar(32) [ref: > incident.sys_id]
  reopened_time datetime
  problem_id varchar(32) [ref: > problem.sys_id]
  caller_id varchar(32) [ref: > sys_user.sys_id]
  subcategory varchar(255)
}

