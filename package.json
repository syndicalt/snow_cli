{
  "name": "@syndicalt/snow-cli",
  "version": "3.0.0",
  "description": "CLI tool for ServiceNow automated build and instance management",
  "type": "module",
  "bin": {
    "snow": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "axios": "^1.7.9",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "eventsource": "^2.0.2",
    "open": "^10.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "servicenow",
    "now-assist",
    "cli",
    "snowcli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/syndicalt/snow_cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syndicalt/snow_cli.git"
  },
  "bugs": {
    "url": "https://github.com/syndicalt/snow_cli/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
