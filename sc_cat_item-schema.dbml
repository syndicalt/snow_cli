  human_readable_url_structure varchar(255)
  seo_script varchar(32) [ref: > sys_script_include.sys_id]
  omit_watcher boolean
  public boolean
  id varchar(255) [not null]
  use_seo_script boolean
  draft boolean
  css varchar(255)
  short_description varchar(255)
  category varchar(255)
  internal boolean
}

Table taxonomy [note: 'Taxonomy'] {
  description varchar(255)
  sys_domain_path varchar(255)
  managers varchar(32) [ref: > user_criteria.sys_id]
  sys_domain varchar(255)
  sys_id varchar(255) [pk]
  name varchar(255) [not null]
  active boolean
}

